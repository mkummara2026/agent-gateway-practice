server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Proxies API calls to whatever gateway you point it at (set GATEWAY_URL
    # at container run time, e.g. -e GATEWAY_URL=http://gateway:8080).
    location /api/ {
        proxy_pass ${GATEWAY_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location / {
        try_files $uri /index.html;
    }
}
